# Copy values into your shell environment before running OpenAI-backed steps.
# Example:
#   export OPENAI_API_KEY="sk-..."

OPENAI_API_KEY=

# Optional model/base URL overrides. You can also pass these through CLI flags
# or save them through `better-story settings-gui`.
BETTER_STORY_BASE_URL=
BETTER_STORY_LLM_MODEL=gpt-4o-mini
BETTER_STORY_ASR_MODEL=whisper-1

# Optional separate TTS provider. Use "same" to reuse the main provider.
BETTER_STORY_TTS_PROVIDER=same
BETTER_STORY_TTS_BASE_URL=
BETTER_STORY_TTS_MODEL=gpt-4o-mini-tts
BETTER_STORY_TTS_VOICE=alloy
